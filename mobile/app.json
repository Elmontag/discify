{
  "expo": {
    "name": "Discify",
    "slug": "discify",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#07111f"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.discify.app"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#07111f"
      },
      "package": "com.discify.app"
    },
    "plugins": [
      [
        "expo-camera",
        {
          "cameraPermission": "Discify benötigt Kamerazugriff, um CD-Cover zu fotografieren."
        }
      ],
      "expo-secure-store",
      "expo-sqlite"
    ],
    "newArchEnabled": true
  }
}
