# --- Vision Backend ---
# Choose "anthropic" or "ollama" in the app sidebar.

# Anthropic API Key – https://console.anthropic.com/account/keys
# Required when using the Anthropic backend.
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Ollama base URL – only needed when using the Ollama backend.
# Default: http://localhost:11434
OLLAMA_URL=http://localhost:11434

# --- Discogs ---
# Personal Access Token – https://www.discogs.com/settings/developers
DISCOGS_TOKEN=your_discogs_personal_access_token_here
